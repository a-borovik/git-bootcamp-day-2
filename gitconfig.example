[init]
    # Новые репозитории будут создаваться с веткой main
    defaultBranch = main
[core]
	repositoryformatversion = 0
	filemode = false
	bare = false
	logallrefupdates = true
	symlinks = false
	ignorecase = true
	editor = code --wait
[user]
    name = Borovik Alexander
    email = your@email.com
[alias]
    st = status
    co = checkout
    br = branch
    lg = log --oneline --graph --all --decorate
[remote "origin"]
	url = git@github.com:a-borovik/git-bootcamp-day-2.git
	fetch = +refs/heads/*:refs/remotes/origin/*
